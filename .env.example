# Backend application
BACKEND_APP_NAME="NPA Analysis Backend"
BACKEND_APP_VERSION="0.1.0"
BACKEND_BASE_DIR="backend"
BACKEND_DATABASE_PATH="backend/database/app.db"
BACKEND_DOCUMENTS_DIR="backend/storage/documents"
BACKEND_LOG_DIR="backend/logs"

# Existing retrieval service
RETRIEVAL_SERVICE_URL="http://127.0.0.1:8000"
RETRIEVAL_TOP_K="3"
RETRIEVAL_TIMEOUT_SECONDS="30"

# CometAPI / Claude
COMETAPI_API_KEY=""
COMETAPI_BASE_URL="https://api.cometapi.com/v1"
COMETAPI_MODEL="claude-3-5-haiku-latest"
COMETAPI_TIMEOUT_SECONDS="60"

# Semantic comparison
SEMANTIC_MODEL_NAME="deepvk/USER2-base"
SEMANTIC_SIMILARITY_THRESHOLD="0.82"
SEMANTIC_MODEL_LOCAL_ONLY="false"
SEMANTIC_CACHE_DIR="backend/storage/model_cache"
