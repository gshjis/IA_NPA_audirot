# Backend application
BACKEND_APP_NAME="NPA Analysis Backend"
BACKEND_APP_VERSION="0.1.0"
BACKEND_BASE_DIR="backend"
BACKEND_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/npa_analysis"
BACKEND_DOCUMENTS_DIR="backend/storage/documents"
BACKEND_LOG_DIR="backend/logs"
BACKEND_CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Existing retrieval service
RETRIEVAL_SERVICE_URL="http://127.0.0.1:8000"
RETRIEVAL_TOP_K="3"
RETRIEVAL_TIMEOUT_SECONDS="30"
RETRIEVAL_CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:8001,http://127.0.0.1:8001"
RETRIEVAL_TAGS_PATH="data/raw/base.json"
RETRIEVAL_CORPUS_PATH="data/processed/laws.json"
RETRIEVAL_MODEL_NAME="deepvk/USER2-base"
RETRIEVAL_CACHE_DIR="scripts/data/cache"

# OpenRouter / Grok
COMETAPI_API_KEY=""
COMETAPI_BASE_URL="https://openrouter.ai/api/v1"
COMETAPI_MODEL="x-ai/grok-4.1-fast"
COMETAPI_TIMEOUT_SECONDS="60"

# Semantic comparison
SEMANTIC_MODEL_NAME="deepvk/USER2-base"
SEMANTIC_SIMILARITY_THRESHOLD="0.82"
SEMANTIC_MODEL_LOCAL_ONLY="false"
SEMANTIC_CACHE_DIR="backend/storage/model_cache"
